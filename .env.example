# Postgres — get from Neon (neon.tech) or Supabase (supabase.com)
# Neon: use the pooled connection string for DATABASE_URL, direct for DIRECT_URL
# Supabase: use the transaction pooler for DATABASE_URL, direct for DIRECT_URL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

NEXTAUTH_SECRET="run: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI (mock by default — set to "remote" + ANTHROPIC_API_KEY to use Claude)
NEXT_PUBLIC_AI_MODE=mock
ANTHROPIC_API_KEY=
NEXT_PUBLIC_OLLAMA_BASE_URL=http://localhost:11434

# Intelligence Service — set to Railway URL after backend deploy
INTELLIGENCE_SERVICE_URL=http://localhost:8001
INTELLIGENCE_SERVICE_SECRET=change-me-in-production

# Stripe (optional — demo mode when absent)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_GROWTH=price_growth_monthly
STRIPE_PRICE_SCALE=price_scale_monthly
