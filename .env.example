# Stripe (demo mode when absent)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_GROWTH=price_growth_monthly
STRIPE_PRICE_SCALE=price_scale_monthly
